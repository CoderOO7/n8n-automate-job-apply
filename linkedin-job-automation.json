    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.CRAWL4AI_API_BASE_URL }}/crawl",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"urls\": [\"{{ $json.scrapeUrl }}\"],\n  \"browser_config\": {\n    \"type\": \"BrowserConfig\",\n    \"params\": {\n      \"headless\": true,\n      \"headers\": {\n        \"Accept-Language\": \"en-US,en;q=0.9\",\n        \"Referer\": \"https://www.google.com/\"\n      },\n      \"user_agent_mode\": \"random\",\n      \"ignore_https_errors\": true\n    }\n  },\n  \"crawler_config\": {\n    \"type\": \"CrawlerRunConfig\",\n    \"params\": {\n      \"magic\": true,\n      \"cache_mode\": \"BYPASS\",\n      \"scan_full_page\": true,\n      \"scroll_delay\": 0.6,\n      \"page_timeout\": 45000,\n      \"delay_before_return_html\": 3.0,\n      \"extraction_strategy\": {\n        \"type\": \"JsonCssExtractionStrategy\",\n        \"params\": {\n          \"schema\": {\n            \"name\": \"LinkedInJobDetail\",\n            \"baseSelector\": \"body\",\n            \"fields\": [\n              {\n                \"name\": \"description\",\n                \"selector\": \"div.show-more-less-html__markup\",\n                \"type\": \"text\"\n              },\n              {\n                \"name\": \"criteria\",\n                \"selector\": \"li.description__job-criteria-item\",\n                \"type\": \"list\",\n                \"fields\": [\n                  {\n                    \"name\": \"label\",\n                    \"selector\": \"h3.description__job-criteria-subheader\",\n                    \"type\": \"text\"\n                  },\n                  {\n                    \"name\": \"value\",\n                    \"selector\": \"span.description__job-criteria-text\",\n                    \"type\": \"text\"\n                  }\n                ]\n              }\n            ]\n          }\n        }\n      }\n    }\n  }\n}",
        "options": {
          "timeout": 60000
        }
      },
