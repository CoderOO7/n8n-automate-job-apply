        "jsCode": "const processedUrls = new Set(\n  $input.all().map(item => (item.json.URLS || '').trim().toLowerCase())\n);\n\nconst jobs = $('📦 Aggregate: Jobs').first().json.results || [];\n\nconst fresh = jobs.flat().filter(job => {\n  const url = (job.jobUrl || job.url || '').trim().toLowerCase();\n  return url && !processedUrls.has(url);\n});\n\nreturn fresh.map((job,i) => ({ json: job, pairedItem: i }));"
