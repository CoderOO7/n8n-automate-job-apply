      "parameters": {
        "jsCode": "const items = $input.all();\nif (items.length === 0) {\n  return [{\n    json: {\n      subject: `LinkedIn Job Agent — No matches today`,\n      body: `<p>No matching jobs found today. Will try again tomorrow.</p>`\n    }\n  }];\n}\nconst jobCards = items.map((item, i) => `\n  <div style=\"margin-bottom:30px;padding:20px;border:1px solid #e0e0e0;border-radius:8px;\">\n    <h2 style=\"margin:0 0 4px;\">${i + 1}. ${item.json.title}</h2>\n    <p style=\"margin:0 0 8px;color:#666;\">${item.json.companyName} — <a href=\"${item.json.jobUrl}\">${item.json.jobUrl}</a></p>\n    <h3 style=\"margin:12px 0 6px;\">Cold Email</h3>\n    <pre style=\"background:#f5f5f5;padding:12px;border-radius:6px;white-space:pre-wrap;font-size:13px;\">${item.json.coldEmail}</pre>\n  </div>\n`).join('');\n\nconst body = `\n<div style=\"font-family:Arial,sans-serif;max-width:700px;margin:auto;\">\n  <h1 style=\"color:#0a66c2;\">LinkedIn Job Agent — ${items.length} match${items.length > 1 ? 'es' : ''} today</h1>\n  <p>Here are today's matched jobs with cold emails ready to send:</p>\n  ${jobCards}\n  <hr>\n  <p style=\"color:#999;font-size:12px;\">Generated by your LinkedIn AI Agent • ${new Date().toDateString()}</p>\n</div>\n`;\n\nreturn [{\n  json: {\n    subject: `LinkedIn Job Agent — ${items.length} match${items.length > 1 ? 'es' : ''} found`,\n    body\n  }\n}];"
      },
