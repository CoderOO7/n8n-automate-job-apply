    {
      "parameters": {
        "jsCode": "const url = require('url');\n\nconst config = $('Configuration').first().json;\nconst output = $input.first().json.output;\nconst parsed = typeof output === \"string\" ? JSON.parse(output) : output;\n\nconst GUEST_SEARCH_API = \"https://www.linkedin.com/jobs-guest/jobs/api/seeMoreJobPostings/search\";\nconst JOBS_PER_PAGE = 25;\n\nconst buildLocation = (locationQuery, fallback) => {\n  if (locationQuery?.city) {\n    return locationQuery.state\n      ? `${locationQuery.city}, ${locationQuery.state}`\n      : locationQuery.city;\n  }\n  return fallback;\n};\n\nconst cleanQuery = (q) => q.replace(/\\s+/g, \" \").trim();\n\nconst buildSearchUrl = ({ query, location, jobAgeSec, expLevels, start }) => {\n  const params = new url.URLSearchParams({\n    keywords: query,\n    location,\n    f_TPR: `r${jobAgeSec}`,\n    sortBy: \"DD\",\n    start: String(start)\n  });\n  if (expLevels?.length) params.set(\"f_E\", expLevels.join(\",\"));\n  return `${GUEST_SEARCH_API}?${params.toString()}`;\n};\n\nconst buildSearchTasks = ({ queries, location, jobAgeSec, expLevels, pages }) => {\n  const tasks = [];\n  queries.forEach((rawQuery, queryIdx) => {\n    const query = cleanQuery(rawQuery);\n    for (let page = 0; page < pages; page++) {\n      tasks.push({\n        searchUrl: buildSearchUrl({\n          query,\n          location,\n          jobAgeSec,\n          expLevels,\n          start: page * JOBS_PER_PAGE\n        }),\n        location,\n        query,\n        page,\n        queryIdx\n      });\n    }\n  });\n  return tasks;\n};\n\nconst tasks = buildSearchTasks({\n  queries: parsed.searchQueries || [],\n  location: buildLocation(parsed.locationQuery, config.targetLocation),\n  jobAgeSec: config.jobsMaxAgeSeconds ?? 86400,\n  expLevels: parsed.experienceLevels || [],\n  pages: config.pagesPerQuery ?? 2\n});\n\nreturn tasks.map((t, i) => ({\n  json: t,\n  pairedItem: 0\n}));"
      },
