    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.CRAWL4AI_API_BASE_URL }}/crawl",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"urls\": [\"{{ $json.searchUrl }}\"],\n  \"browser_config\": {\n    \"type\": \"BrowserConfig\",\n    \"params\": {\n      \"headless\": true,\n      \"headers\": {\n        \"Accept-Language\": \"en-US,en;q=0.9\",\n        \"Referer\": \"https://www.google.com/\"\n      },\n      \"user_agent_mode\": \"random\",\n      \"ignore_https_errors\": true\n    }\n  },\n  \"crawler_config\": {\n    \"type\": \"CrawlerRunConfig\",\n    \"params\": {\n      \"magic\": true,\n      \"cache_mode\": \"BYPASS\",\n      \"scan_full_page\": true,\n      \"scroll_delay\": 0.6,\n      \"page_timeout\": 45000,\n      \"delay_before_return_html\": 3.0,\n      \"extraction_strategy\": {\n        \"type\": \"JsonCssExtractionStrategy\",\n        \"params\": {\n          \"schema\": {\n            \"name\": \"linkedin_jobs\",\n            \"baseSelector\": \"li\",\n            \"fields\": [\n              { \"name\": \"title\", \"selector\": \"h3.base-search-card__title\", \"type\": \"text\" },\n              { \"name\": \"companyName\", \"selector\": \"h4.base-search-card__subtitle\", \"type\": \"text\" },\n              { \"name\": \"location\", \"selector\": \".job-search-card__location\", \"type\": \"text\" },\n              { \"name\": \"jobUrl\", \"selector\": \"a.base-card__full-link\", \"type\": \"attribute\", \"attribute\": \"href\"},\n              { \"name\": \"postedAt\", \"selector\": \"time\", \"type\": \"attribute\", \"attribute\": \"datetime\" }\n            ]\n          }\n        }\n      }\n    }\n  }\n}",
        "options": {
          "timeout": 90000
        }
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -8992,
        640
      ],
      "id": "6b7bae5f-20bc-4d2d-a667-642aa0a43558",
      "name": "Crawl4AI Scrap Jobs",
      "alwaysOutputData": true,
      "retryOnFail": true,
      "waitBetweenTries": 5000
    },
    {
      "parameters": {
        "jsCode": "const PUBLIC_JOB_URL = (id) => `https://www.linkedin.com/jobs/view/${id}`;\nconst SCRAPE_JOB_URL = (id) =>\n  `https://www.linkedin.com/jobs-guest/jobs/api/jobPosting/${id}`;\n\nconst getJobIdFromUrl = (jobUrl) => {\n  if (!jobUrl) return null;\n  return (\n    String(jobUrl).split(\"?\")[0].replace(/\\/$/, \"\").split(\"-\").pop() || null\n  );\n};\n\nconst parseExtracted = (raw) => {\n  let ec = raw;\n  if (typeof ec === \"string\") {\n    try {\n      ec = JSON.parse(ec);\n    } catch {\n      return [];\n    }\n  }\n  return Array.isArray(ec) ? ec : [];\n};\n\nconst buildJob = (card) => {\n  const jobId = getJobIdFromUrl(card.jobUrl);\n  if (!jobId) return null;\n  return {\n    jobId,\n    jobUrl: PUBLIC_JOB_URL(jobId),\n    scrapeUrl: SCRAPE_JOB_URL(jobId),\n    title: (card.title || \"\").trim(),\n    companyName: (card.companyName || \"\").trim(),\n    location: (card.location || \"\").trim(),\n    postedAt: card.postedAt || \"\",\n  };\n};\n\nconst collectJobs = (resp) => {\n  const out = [];\n  const seen = new Set();\n\n  for (let i = 0; i < resp.length; i++) {\n    const cards = parseExtracted(resp[i].json.results?.[0]?.extracted_content);\n\n    for (const card of cards) {\n      const job = buildJob(card);\n      if (!job || seen.has(job.jobId)) continue;\n      seen.add(job.jobId);\n      out.push({ json: job, pairedItem: { item: i } });\n    }\n  }\n  return out;\n};\n\nreturn collectJobs($input.all());"
      },
