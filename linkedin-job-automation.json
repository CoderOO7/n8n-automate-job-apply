        "jsCode": "const config = $(\"⚙️ Configuration\").first().json;\nconst jobs = $input.first().json.data;\n\nreturn jobs.map((job) => {\n  const coldEmail = `Subject: Application for ${job.title} role\n\nHi Team,\n\nI came across the job posting for ${job.title} at ${job.companyName} and believe my background aligns well and  I'm confident that I can contribute effectively to the team.\n\nI have attached my resume for your review and look forward to hearing from you.\n\nThanks,\n${config.candidateName}\n${config.candidateMobile}`;\n\n  return  {\n    ...job,\n    coldEmail: coldEmail,\n    dateApplied: new Date().toISOString().split(\"T\")[0],\n  };\n});\n"
