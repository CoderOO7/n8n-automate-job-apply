    {
      "parameters": {
        "jsCode": "const MAX_DESC_LEN = 10000;\n\nconst parseExtracted = (raw) => {\n  let ec = raw;\n  if (typeof ec === \"string\") {\n    try {\n      ec = JSON.parse(ec);\n    } catch {\n      return [];\n    }\n  }\n  return Array.isArray(ec) ? ec : ec ? [ec] : [];\n};\n\nconst cleanDescription = (text) =>\n  String(text || \"\")\n    .replace(/\\s+/g, \" \")\n    .trim()\n    .slice(0, MAX_DESC_LEN);\n\nconst extractDetail = (rawJob) => {\n  const items = parseExtracted(rawJob.json?.results?.[0]?.extracted_content);\n  return items[0] || {};\n};\n\nconst mergeJobDetail = (job, rawJob) => {\n  const detail = extractDetail(rawJob);\n  return {\n    ...job,\n    description: cleanDescription(detail.description),\n  };\n};\n\nconst rawJobDetails = $input.all();\nconst newJobs = $(\"Remove Already Processed Jobs\").all();\n\nreturn rawJobDetails.map((rawJob, i) => ({\n  json: mergeJobDetail(newJobs[i]?.json || {}, rawJob),\n  pairedItem: i,\n}));"
      },
