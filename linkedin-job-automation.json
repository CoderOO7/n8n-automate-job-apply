      "parameters": {
        "promptType": "define",
        "text": "=Build a precise job search strategy from these profile sources.\n\nCandidate:\n- Name: {{ $('⚙️ Configuration').item.json.candidateName }}\n- Target location: {{ $('⚙️ Configuration').item.json.targetLocation }}\n- Remote preference: {{ $('⚙️ Configuration').item.json.remotePreference }}\n- Minimum annual salary: {{ $('⚙️ Configuration').item.json.minimumSalaryAnnual }}\n\nProfile Source Content:\n{{ JSON.stringify($json.results) }}\n\nFields to return:\n- primaryRoles: array of max 3 job titles\n- secondaryRoles: array of max 2 related roles\n- coreSkills: top 6 skills only\n- seniority: single string like \"Mid-level\" or \"Senior\"\n- expectedSalary: single string\n- searchQueries: exactly 3 job title keywords, no location, no city. Example: \"Full Stack Developer\", \"Backend Engineer\", \"Node.js Developer\"\n- exclusions: terms to avoid in job search\n- locationQuery: object with city and state fields\n- rationale: one sentence explanation",
        "hasOutputParser": true,
        "options": {
          "systemMessage": "You are a profile intelligence agent for job search automation. Infer realistic target roles and search queries from resume and LinkedIn profile content.\n\nRules:\n1. Keep searchQueries to exactly 3 items\n2. Search queries must be job title keywords only— no location, no city names, no remote or hybrid words\n3. Keep coreSkills to top 6 most relevant skills only\n4. Keep primaryRoles to max 3 items\n5. Keep secondaryRoles to max 2 items\n6. seniority must be a single string like \"Mid-level\", \"Senior\", \"Junior\"\n7. CRITICAL: Return pure JSON only — no markdown, no code fences, no backticks, no extra explanation. The output parser requires clean raw JSON. No additional fields simple one level plain object that can be used by parser.",
          "maxIterations": 1
        }
      },
